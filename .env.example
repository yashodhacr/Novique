# Copy to .env and fill in. docker-compose reads these.

# Optional: enables the AI Explainer Engine (Claude). Without it, the pipeline
# falls back to a deterministic heuristic summarizer so the slice still runs.
ANTHROPIC_API_KEY=

# Model used by the summarizer. Default is the most capable model.
# For high-volume ingestion you may prefer claude-haiku-4-5 for cost.
AI_MODEL=claude-opus-4-8

# JWT signing secret for auth. A dev default is baked in, but set a strong
# value (>=32 chars) for anything beyond local testing.
JWT_SECRET=
